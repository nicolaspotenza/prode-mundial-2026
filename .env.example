# Copiá este archivo a ".env" y completá las keys que tengas. Vite solo expone las que
# empiezan con VITE_. Sin keys, la app usa TheSportsDB (gratis, cobertura limitada).

# API-Football (api-sports.io) — free tier 100 req/día, COBERTURA COMPLETA del Mundial.
# Registrate en https://www.api-football.com/ -> Dashboard -> tu API key.
# Al definirla, pasa a ser la fuente principal automáticamente.
VITE_API_FOOTBALL_KEY=

# football-data.org — free tier, requiere token (https://www.football-data.org/).
VITE_FOOTBALL_DATA_KEY=

# TheSportsDB — opcional. Key premium para cobertura completa (la pública por defecto es "123").
VITE_THESPORTSDB_KEY=
